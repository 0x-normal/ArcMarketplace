# ─── Circle Developer Credentials ───
# Get these from https://console.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ─── Arc Network Contract Addresses ───
# ERC-8004 Identity Registry on Arc Testnet
IDENTITY_REGISTRY_ADDRESS=0x0216e88B7E7817eB2eCEC746739B4E1B3F4B0169
# ArcMarketplace contract (deploy first, then set)
MARKETPLACE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Arc Testnet ───
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ─── Marketplace Config ───
# Platform fee in basis points (default: 250 = 2.5%)
PLATFORM_FEE_BPS=250
# Escrow timeout in seconds (default: 7 days = 604800)
ESCROW_TIMEOUT_SECONDS=604800
# Dispute resolution timeout (default: 14 days = 1209600)
DISPUTE_TIMEOUT_SECONDS=1209600

# ─── Server ───
PORT=3220
